<Window x:Class="SimpleCalculatorFactory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор (Фабрика)" Height="450" Width="350" MinHeight="350" MinWidth="250">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="DisplayTextBox" Grid.Row="0" Grid.ColumnSpan="4" 
                 FontSize="36" TextAlignment="Right" VerticalContentAlignment="Bottom" 
                 IsReadOnly="True" Text="0" Margin="0,0,0,10"/>

        <Button Content="C" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="CE" Grid.Row="1" Grid.Column="2" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="/" Grid.Row="1" Grid.Column="3" Margin="2" FontSize="20" Click="AnyButton_Click"/>

        <Button Content="7" Grid.Row="2" Grid.Column="0" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="8" Grid.Row="2" Grid.Column="1" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="9" Grid.Row="2" Grid.Column="2" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="*" Grid.Row="2" Grid.Column="3" Margin="2" FontSize="20" Click="AnyButton_Click"/>

        <Button Content="4" Grid.Row="3" Grid.Column="0" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="5" Grid.Row="3" Grid.Column="1" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="6" Grid.Row="3" Grid.Column="2" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="-" Grid.Row="3" Grid.Column="3" Margin="2" FontSize="20" Click="AnyButton_Click"/>

        <Button Content="1" Grid.Row="4" Grid.Column="0" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="2" Grid.Row="4" Grid.Column="1" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="3" Grid.Row="4" Grid.Column="2" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="+" Grid.Row="4" Grid.Column="3" Margin="2" FontSize="20" Click="AnyButton_Click"/>

        <Button Content="0" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="2" FontSize="20" Click="AnyButton_Click"/>
        <Button Content="=" Grid.Row="5" Grid.Column="3" Margin="2" FontSize="20" Click="AnyButton_Click"/>
    </Grid>
</Window>
<Window x:Class="SimpleCalculatorMVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SimpleCalculatorMVVM.ViewModels"
        Title="Калькулятор (MVVM + Команда)" Height="450" Width="350" MinHeight="350" MinWidth="250">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0" Grid.ColumnSpan="4" FontSize="36" TextAlignment="Right" VerticalContentAlignment="Bottom" IsReadOnly="True" Text="{Binding Display}" Margin="0,0,0,10"/>

        <Button Content="C" Grid.Row="1" Grid.Column="0" Margin="2" FontSize="20" Command="{Binding ClearCommand}" CommandParameter="C"/>
        <Button Content="Отмена" Grid.Row="1" Grid.Column="1" Margin="2" FontSize="16" Command="{Binding UndoCommand}"/>
        <Button Content="CE" Grid.Row="1" Grid.Column="2" Margin="2" FontSize="20" Command="{Binding ClearCommand}" CommandParameter="CE"/>
        <Button Content="/" Grid.Row="1" Grid.Column="3" Margin="2" FontSize="20" Command="{Binding OperationCommand}" CommandParameter="/"/>

        <Button Content="7" Grid.Row="2" Grid.Column="0" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="7"/>
        <Button Content="8" Grid.Row="2" Grid.Column="1" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="8"/>
        <Button Content="9" Grid.Row="2" Grid.Column="2" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="9"/>
        <Button Content="*" Grid.Row="2" Grid.Column="3" Margin="2" FontSize="20" Command="{Binding OperationCommand}" CommandParameter="*"/>

        <Button Content="4" Grid.Row="3" Grid.Column="0" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="4"/>
        <Button Content="5" Grid.Row="3" Grid.Column="1" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="5"/>
        <Button Content="6" Grid.Row="3" Grid.Column="2" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="6"/>
        <Button Content="-" Grid.Row="3" Grid.Column="3" Margin="2" FontSize="20" Command="{Binding OperationCommand}" CommandParameter="-"/>

        <Button Content="1" Grid.Row="4" Grid.Column="0" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="1"/>
        <Button Content="2" Grid.Row="4" Grid.Column="1" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="2"/>
        <Button Content="3" Grid.Row="4" Grid.Column="2" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="3"/>
        <Button Content="+" Grid.Row="4" Grid.Column="3" Margin="2" FontSize="20" Command="{Binding OperationCommand}" CommandParameter="+"/>

        <Button Content="0" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="2" FontSize="20" Command="{Binding DigitCommand}" CommandParameter="0"/>
        <Button Content="=" Grid.Row="5" Grid.Column="3" Margin="2" FontSize="20" Command="{Binding EqualsCommand}"/>
    </Grid>
</Window>